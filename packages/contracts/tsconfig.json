{
  "ts-node": {
    "moduleTypes": {
      "../../examples/games/zk-core/**": "cjs",
      "../../examples/games/hilo-war/**": "cjs"
    }
  },
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  }
}