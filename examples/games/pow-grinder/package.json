{
  "name": "@gibs/pow-grinder",
  "version": "0.0.1",
  "private": true,
  "description": "Fast native/WASM MsgBoard proof-of-work stamper (bit-identical to the reth node verifier)",
  "main": "index.js",
  "types": "index.d.ts",
  "files": ["index.js", "index.d.ts", "pow-grinder.*.node", "pkg"],
  "scripts": {
    "build:native": "cargo build --release --features napi && bash scripts/copy-native.sh",
    "build:wasm": "wasm-pack build --release --target web --out-dir pkg -- --no-default-features --features wasm",
    "test": "cargo test --release"
  }
}
